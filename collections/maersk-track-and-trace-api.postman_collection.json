          "name": "List Shipment Tracking Events",
          "request": {
            "name": "List Shipment Tracking Events",
            "description": {
              "content": "Retrieve neutralized tracking events for a shipment referenced by container number, bill-of-lading number, or booking number. Returns location, vessel, voyage, planned and actual timestamps for each milestone.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "track-and-trace-private",
                "shipments"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "equipmentReference",
                  "value": "<string>",
                  "description": "Container number (ISO 6346)."
                },
                {
                  "disabled": false,
                  "key": "transportDocumentReference",
                  "value": "<string>",
                  "description": "Bill of lading number."
                },
                {
                  "disabled": false,
                  "key": "carrierBookingReference",
                  "value": "<string>",
                  "description": "Booking reference number."
                }
